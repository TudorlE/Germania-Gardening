# Gmail SMTP credentials for the contact form
# 1. Sign in to the Gmail account that should SEND the messages.
# 2. Enable 2-Step Verification at https://myaccount.google.com/security
# 3. Create an "App password" (Mail) at https://myaccount.google.com/apppasswords
# 4. Copy the 16-character app password below (without spaces).
# 5. Rename this file to ".env.local" — never commit the real values.

GMAIL_USER=your-sender-address@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where contact form messages will be delivered.
# Defaults to mpetrasco@web.de if omitted.
CONTACT_TO=mpetrasco@web.de
